{
  // Where the LeagueTracker server(s) live (the Docker host). From the gaming
  // PC use the tracker machine's LAN address. Multiple accounts = multiple
  // instances, comma-separated: "http://192.168.1.50:5170,http://192.168.1.50:5171".
  "ServerUrl": "http://localhost:5170,http://localhost:5171",

  // Blank = auto-detect (<drive>:\Riot Games\League of Legends on every drive).
  "LeaguePath": "",

  // Blank = "ffmpeg" from PATH, falling back to ffmpeg.exe next to this exe.
  "FfmpegPath": "",

  "AgentName": "",
  "PollSeconds": 60,
  "CaptureFramerate": 30,

  // Live-game recording (Ascent-style auto-VOD): while you are in a real
  // game, the game window is captured to an mp4 (NVENC) with a sidecar json
  // (match id, clock map) for review. Blank RecordingsDir = <My Videos>\LeagueTracker.
  "RecordGames": true,
  "RecordingsDir": "",
  "RecordFramerate": 60,
  "RecordQuality": 26,
  // Which queues to record: ranked-solo, ranked-flex, normal, aram, clash,
  // coop-ai, urf, nexus-blitz, arena, brawl, doom-bots, custom, or all.
  "RecordQueues": "ranked-solo,normal",

  // Cloudflare Access service token (Zero Trust > Access > Service Auth) for
  // trackers behind an Access wall. Blank = no Access (dev against localhost).
  "CfAccessClientId": "",
  "CfAccessClientSecret": "",

  // 0 = render every planned window. Set to 1 for a quick smoke test.
  "MaxWindowsPerJob": 0
}
