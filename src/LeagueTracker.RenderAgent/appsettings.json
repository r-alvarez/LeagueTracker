{
  // Where the LeagueTracker server(s) live (the Docker host). From the gaming
  // PC use the tracker machine's LAN address. Multiple accounts = multiple
  // instances, comma-separated: "http://192.168.1.50:5170,http://192.168.1.50:5171".
  "ServerUrl": "http://localhost:5170,http://localhost:5171",

  // Blank = auto-detect (<drive>:\Riot Games\League of Legends on every drive).
  "LeaguePath": "",

  // Blank = "ffmpeg" from PATH, falling back to ffmpeg.exe next to this exe.
  "FfmpegPath": "",

  "AgentName": "",
  "PollSeconds": 60,
  "CaptureFramerate": 30,

  // 0 = render every planned window. Set to 1 for a quick smoke test.
  "MaxWindowsPerJob": 0
}
